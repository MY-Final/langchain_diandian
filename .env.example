# OpenAI 兼容接口配置
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=http://your-openai-compatible-host/v1
OPENAI_MODEL=your-model

# system prompt 文件路径；也可以改成直接在 .env 里写 SYSTEM_PROMPT
SYSTEM_PROMPT_FILE=prompts/system_prompt.txt

# 是否在控制台打印 LangChain tool 调用记录
CHAT_DEBUG_TOOL_CALLS=false

# 是否启用滚动摘要记忆；true 表示旧对话会在超阈值后压缩成摘要
CHAT_MEMORY_ENABLE_SUMMARY=true

# 私聊记忆窗口：最近保留多少轮原始对话
PRIVATE_CHAT_MEMORY_MAX_TURNS=12

# 私聊在超过多少轮后开始压缩旧上下文
PRIVATE_CHAT_MEMORY_SUMMARY_TRIGGER_TURNS=16

# 私聊每次压缩多少轮最旧对话到摘要里
PRIVATE_CHAT_MEMORY_SUMMARY_BATCH_TURNS=6

# 群聊记忆窗口：最近保留多少轮原始对话
GROUP_CHAT_MEMORY_MAX_TURNS=8

# 群聊在超过多少轮后开始压缩旧上下文
GROUP_CHAT_MEMORY_SUMMARY_TRIGGER_TURNS=12

# 群聊每次压缩多少轮最旧对话到摘要里
GROUP_CHAT_MEMORY_SUMMARY_BATCH_TURNS=4

# 摘要最大字符数，防止摘要本身越来越长
CHAT_MEMORY_MAX_SUMMARY_CHARS=1200

# 单次送给模型的上下文字符上限，超过时会进一步裁剪
CHAT_MEMORY_MAX_INPUT_CHARS=12000

# 是否启用 PostgreSQL；启用后启动时会自动初始化记忆相关表
POSTGRES_ENABLED=false

# PostgreSQL 连接串；如果填写，会优先使用它（同时支持本地和远程）
# 例：postgresql://postgres:password@127.0.0.1:5432/diandian
# 例：postgresql://user:password@your-host:5432/diandian?sslmode=require
POSTGRES_DSN=

# 未提供 POSTGRES_DSN 时，使用以下拆分配置
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=diandian
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=prefer
POSTGRES_CONNECT_TIMEOUT=10

# NapCat / OneBot WebSocket 地址
NAPCAT_WS_URL=ws://your-host:3001/

# NapCat 鉴权 token；如果未开启鉴权可以留空
NAPCAT_TOKEN=

# 在群里呼叫 bot 的名字或正则，多个用英文逗号分隔
ONEBOT_BOT_NAME_PATTERNS=点点,小点点

# 受信操作员用户 ID，多个用英文逗号分隔；用于启用高风险私聊技能（删好友、改资料等）
ONEBOT_OPERATOR_USER_IDS=

# 回复时是否自动引用原消息；true 为引用回复，false 为普通回复
ONEBOT_REPLY_WITH_QUOTE=true

# 是否启用分段回复；true 时优先按显式分隔标记拆分，超长时才会安全切分
ONEBOT_REPLY_SPLIT_ENABLED=true

# 单条回复消息的最大字符数，超过后会继续拆分
ONEBOT_REPLY_SPLIT_MAX_CHARS=180

# 显式分段标记；模型输出中出现该标记时会按它拆成多条消息
ONEBOT_REPLY_SPLIT_MARKER=[SPLIT]

# ============================================================
# 消息索引（Redis）配置
# ============================================================

# 是否启用消息索引
MESSAGE_INDEX_ENABLED=true

# Redis 连接 URL（支持本地 redis:// 和远程 rediss:// TLS）
MESSAGE_INDEX_REDIS_URL=redis://127.0.0.1:6379/0

# Redis key 前缀
MESSAGE_INDEX_KEY_PREFIX=obmsg

# 索引数据 TTL（秒），默认 2 天
MESSAGE_INDEX_TTL_SECONDS=172800

# 每个会话保留最近 N 条消息
MESSAGE_INDEX_CHAT_MAXLEN=200

# 每个用户在单会话内保留最近 N 条消息
MESSAGE_INDEX_USER_MAXLEN=100

# 每个会话内 bot 自己保留最近 N 条消息
MESSAGE_INDEX_SELF_MAXLEN=100

# 撤回时间窗口（秒），默认 2 分钟
MESSAGE_INDEX_RECALL_WINDOW_SECONDS=120

# Redis 连接超时（毫秒）
MESSAGE_INDEX_CONNECT_TIMEOUT_MS=3000

# Redis 读写超时（毫秒）
MESSAGE_INDEX_SOCKET_TIMEOUT_MS=3000

# 群管理模式下是否放开 bot 自己消息的时间窗口限制
MESSAGE_INDEX_GROUP_SELF_NO_WINDOW_WHEN_ADMIN=true
